# ============================================================
# ReviewLens AI — Environment Variables
# ============================================================
# Copy this file to `.env` in the project root and fill in
# your real values. Lines starting with # are comments.
#
# IMPORTANT: Never commit your real .env file to git.
#            .env is already in .gitignore.
# ============================================================


# ┌─────────────────────────────────────────────────────────┐
# │  FRONTEND (Vite — exposed to browser via VITE_ prefix) │
# └─────────────────────────────────────────────────────────┘

# Your Supabase project URL (Dashboard → Settings → API → Project URL)
# Example: https://abcdefghij.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key (Dashboard → Settings → API → anon public)
# This key is safe to expose in the browser — it only grants
# access allowed by your Row-Level Security policies.
VITE_SUPABASE_ANON_KEY=your-anon-key


# ┌─────────────────────────────────────────────────────────┐
# │  EDGE FUNCTION SECRETS (server-side only — never in     │
# │  the browser bundle)                                    │
# └─────────────────────────────────────────────────────────┘
#
# These variables are used by Supabase Edge Functions via
# Deno.env.get(). They must be set as Supabase secrets:
#
#   supabase secrets set \
#     OPENAI_API_KEY=sk-... \
#     PINECONE_API_KEY=pcsk_... \
#     PINECONE_INDEX=reviewlensai
#
# You can verify they're set with:
#   supabase secrets list

# OpenAI API key (https://platform.openai.com/api-keys)
# Used by: extract-reviews (GPT-4o function calling)
#          embed-reviews   (text-embedding-3-small)
#          chat-rag        (GPT-4o streaming)
# OPENAI_API_KEY=sk-...

# Pinecone API key (https://app.pinecone.io → API Keys)
# Used by: embed-reviews (vector upsert)
#          chat-rag       (vector query)
# PINECONE_API_KEY=pcsk_...

# Pinecone index name — must match the index you created in the
# Pinecone console. Our index is named "reviewlensai".
# Dimension: 1536 (matches text-embedding-3-small output)
# Metric:    cosine
# Used by: embed-reviews, chat-rag
# PINECONE_INDEX=reviewlensai


# ┌─────────────────────────────────────────────────────────┐
# │  QUICK SETUP CHECKLIST                                  │
# └─────────────────────────────────────────────────────────┘
#
# 1. Create a Supabase project → copy URL + anon key above
# 2. Run the DB migration:
#      supabase db push
#    (or paste supabase/migrations/*.sql into the SQL editor)
# 3. Create a Pinecone index named "reviewlensai":
#      Dimension: 1536 | Metric: cosine | Region: us-east-1
# 4. Set Edge Function secrets (see command above)
# 5. Deploy Edge Functions:
#      supabase functions deploy extract-reviews
#      supabase functions deploy embed-reviews
#      supabase functions deploy chat-rag
# 6. Start the dev server:
#      npm run dev
